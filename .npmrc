# Suppress npm warnings about deprecated configs
audit-level=moderate
fund=false
# Use legacy peer deps to avoid conflicts during CI/CD
legacy-peer-deps=true
# Do not enforce engine versions (allow install on other Node/npm versions)
engine-strict=false
# Package integrity verification
package-lock=true
strict-ssl=true
# Enforce exact versions (no ranges) for all future installs
save-exact=true
# Supply-chain cooldown: only resolve versions published at least 7 days ago
# (security fixes blocked by this can use min-release-age-exclude or temporary override)
min-release-age=7
