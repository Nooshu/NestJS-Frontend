{#
  Navigation macro for journey pages.
  Renders breadcrumb navigation using the official govukBreadcrumbs macro.
#}
{% macro journeyNavigation(journey, currentPage) %}
  {% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}

  {% if journey == 'new-journey' %}
    {% set pages = [
      { path: "/new-journey", title: "Welcome", id: "index" },
      { path: "/new-journey/start", title: "Start", id: "start" },
      { path: "/new-journey/details", title: "Details", id: "details" },
      { path: "/new-journey/confirmation", title: "Confirmation", id: "confirmation" }
    ] %}
  {% else %}
    {% set pages = [
      { path: "/", title: "Home", id: "index" },
      { path: "/second-page", title: "Second Page", id: "second-page" },
      { path: "/third-page", title: "Third Page", id: "third-page" }
    ] %}
  {% endif %}

  {% set breadcrumbItems = [] %}
  {% for page in pages %}
    {% if page.id == currentPage %}
      {% set breadcrumbItems = (breadcrumbItems.push({ text: page.title }), breadcrumbItems) %}
    {% else %}
      {% set breadcrumbItems = (breadcrumbItems.push({ text: page.title, href: page.path }), breadcrumbItems) %}
    {% endif %}
  {% endfor %}

  {{ govukBreadcrumbs({
    items: breadcrumbItems
  }) }}
{% endmacro %}
