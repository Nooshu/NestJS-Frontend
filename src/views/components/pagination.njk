{#
  Pagination wrapper — maps this app's page-list shape onto govukPagination.

  Why a thin wrapper: journeys pass `{ path, title }[]` plus the current path;
  the official macro expects `items` / `previous` / `next`. Keep GOV.UK markup
  exclusively in `govukPagination` (SSoT); this file only transforms data and
  chooses prev/next based on position (first / middle / last / single page).

  @param pages - Array of { path: string, title: string }
  @param currentPagePath - Active page path (compared with `==` to each page.path)

  Usage:
    {% from "components/pagination.njk" import pagination %}
    {{ pagination(pages, currentPath) }}
#}
{% macro pagination(pages, currentPagePath) %}
  {% from "govuk/components/pagination/macro.njk" import govukPagination %}

  {% set items = [] %}
  {% for page in pages %}
    {% set items = (items.push({
      number: loop.index,
      href: page.path,
      current: page.path == currentPagePath
    }), items) %}
  {% endfor %}

  {% for page in pages %}
    {% if page.path == currentPagePath and not loop.first and not loop.last %}
      {{ govukPagination({
        items: items,
        previous: {
          href: pages[loop.index0 - 1].path,
          labelText: pages[loop.index0 - 1].title
        },
        next: {
          href: pages[loop.index0 + 1].path,
          labelText: pages[loop.index0 + 1].title
        }
      }) }}
    {% elif page.path == currentPagePath and loop.first and not loop.last %}
      {{ govukPagination({
        items: items,
        next: {
          href: pages[loop.index0 + 1].path,
          labelText: pages[loop.index0 + 1].title
        }
      }) }}
    {% elif page.path == currentPagePath and loop.last and not loop.first %}
      {{ govukPagination({
        items: items,
        previous: {
          href: pages[loop.index0 - 1].path,
          labelText: pages[loop.index0 - 1].title
        }
      }) }}
    {% elif page.path == currentPagePath %}
      {{ govukPagination({
        items: items
      }) }}
    {% endif %}
  {% endfor %}
{% endmacro %}
