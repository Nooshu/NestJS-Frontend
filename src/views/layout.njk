{#
  Base page layout — GOV.UK Frontend is the single source of truth for UI chrome.

  Why macros (not hand-written HTML): skip-link, header, and footer markup must come
  from official Nunjucks macros so Design System upgrades land via the package, not
  local class tweaks. Typography/layout utilities (govuk-width-container, etc.) are
  fine for page composition; component structure must still use macros.

  Child templates: `{% extends "layout.njk" %}` and fill `{% block content %}`.
  Assets: prefer `assetPath(...)` for fingerprinted CSS/JS; GOVUKFrontend.initAll()
  runs after the GOV.UK bundle so progressive-enhancement classes apply.
#}
<!DOCTYPE html>
<html class="govuk-template" lang="en">
  <head>
    <meta charset="utf-8">
    <title>{{ title }} - GOV.UK</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="theme-color" content="#1d70b8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet, noimageindex">
    <meta name="googlebot" content="noindex, nofollow, noarchive, nosnippet, noimageindex">
    <link rel="icon" sizes="48x48" href="{{ assetPath('/assets/images/favicon.ico') }}">
    <link rel="icon" sizes="any" href="{{ assetPath('/assets/images/favicon.svg') }}" type="image/svg+xml">
    <link rel="mask-icon" href="{{ assetPath('/assets/images/govuk-icon-mask.svg') }}" color="#1d70b8">
    <link rel="apple-touch-icon" href="{{ assetPath('/assets/images/govuk-icon-180.png') }}">
    <meta property="og:image" content="{{ assetPath('/assets/images/govuk-opengraph-image.png') }}">
    <link href="{{ assetPath('/govuk/govuk-frontend.min.css') }}" rel="stylesheet">
  </head>
  <body class="govuk-template__body">
    <script>
      document.body.className += ' js-enabled' + ('noModule' in HTMLScriptElement.prototype ? ' govuk-frontend-supported' : '');
    </script>
    {% from "govuk/components/skip-link/macro.njk" import govukSkipLink %}
    {% from "govuk/components/header/macro.njk" import govukHeader %}
    {% from "govuk/components/footer/macro.njk" import govukFooter %}

    {{ govukSkipLink({
      href: "#main-content",
      text: "Skip to main content"
    }) }}

    <header class="govuk-template__header">
      {{ govukHeader({
        homepageUrl: "/"
      }) }}
    </header>
    <div class="govuk-width-container">
      <main class="govuk-main-wrapper" id="main-content" role="main">
        {% block content %}{% endblock %}
      </main>
    </div>
    <footer class="govuk-template__footer">
      {{ govukFooter({
        meta: {
          items: [
            {
              href: "/",
              text: "Home"
            }
          ]
        }
      }) }}
    </footer>
    <script src="{{ assetPath('/govuk/all.bundle.js') }}"></script>
    <script>window.GOVUKFrontend.initAll()</script>
    <script type="module" src="/js/main.js?v=202409171600"></script>
  </body>
</html>
